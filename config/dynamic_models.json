{
  "model_discovery": {
    "enable_automatic_discovery": true,
    "discovery_sources": ["database", "huggingface_api", "local_registry"],
    "refresh_interval_hours": 24,
    "max_models_per_category": 10
  },
  "model_selection_criteria": {
    "image_classification": {
      "min_downloads": 1000,
      "preferred_architectures": ["vit", "resnet", "efficientnet", "deit"],
      "excluded_keywords": ["private", "gated", "restricted"],
      "performance_threshold": 0.7,
      "max_model_size_gb": 2
    },
    "automatic_speech_recognition": {
      "min_downloads": 500,
      "preferred_architectures": ["whisper", "wav2vec2", "speecht5"],
      "excluded_keywords": ["private", "gated", "restricted"],
      "language_support": ["en", "multilingual"],
      "max_model_size_gb": 3
    },
    "text_generation": {
      "min_downloads": 1000,
      "preferred_architectures": ["llama", "mistral", "phi", "qwen"],
      "excluded_keywords": ["private", "gated", "restricted"],
      "max_parameters_b": 7,
      "instruction_tuned_preferred": true
    }
  },
  "dynamic_config_rules": {
    "timeout_scaling": {
      "small_model_gb": 1,
      "medium_model_gb": 3,
      "large_model_gb": 7,
      "timeout_multipliers": {
        "small": 1.0,
        "medium": 1.5,
        "large": 2.0
      }
    },
    "rate_limit_scaling": {
      "free_tier_models": 60,
      "standard_models": 100,
      "premium_models": 200
    },
    "cost_estimation": {
      "default_cost_per_1k_tokens": 0.001,
      "model_size_multipliers": {
        "small": 0.5,
        "medium": 1.0,
        "large": 2.0
      }
    }
  },
  "fallback_strategies": {
    "image_classification": [
      "database_query",
      "huggingface_search",
      "default_accessible_models"
    ],
    "automatic_speech_recognition": [
      "database_query", 
      "huggingface_search",
      "whisper_variants",
      "wav2vec2_variants"
    ],
    "text_generation": [
      "database_query",
      "huggingface_search", 
      "instruction_tuned_models",
      "general_purpose_models"
    ]
  },
  "model_validation": {
    "check_accessibility": true,
    "validate_downloads": true,
    "test_loading": false,
    "cache_validation_results": true,
    "validation_timeout_seconds": 30
  },
  "auto_update": {
    "enable_auto_update": true,
    "update_frequency": "daily",
    "backup_old_configs": true,
    "notify_on_changes": true
  }
} 